# ── modelo ──────────────────────────────────────────────────────────────────
# Nome do modelo HuggingFace (ex: Qwen/Qwen2.5-1.5B-Instruct, meta-llama/Llama-3.2-1B)
MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# Token HuggingFace (necessário para modelos gated como Llama)
HF_TOKEN=

# Device de inferência: auto | cpu | cuda | mps
DEVICE=auto

# ── seeds ───────────────────────────────────────────────────────────────────
RANDOM_SEED=42
KV_QUANT_SEED=42
